Options -Indexes
RewriteEngine On
# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]
# Revalidate HTML so future fixes propagate immediately
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "no-cache, must-revalidate, max-age=0"
</FilesMatch>

# Server-side env file: never servable over HTTP (Hostinger blocks dotfiles too).
<Files ".env">
  # Apache 2.4 / LiteSpeed
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  # Apache 2.2 fallback
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>
