Options -Indexes
RewriteEngine On
# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]
# Revalidate HTML so future fixes propagate immediately
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "no-cache, must-revalidate, max-age=0"
</FilesMatch>

# Server-side secret: never servable over HTTP (defense-in-depth; file is also return-only).
<Files "kit_secret.php">
  Require all denied
</Files>
