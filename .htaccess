Options -Indexes
DirectoryIndex index.html
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

# Single static apex (concept v1). A/B was removed: the PHP splitter could not
# survive LiteSpeed/hcdn page-cache pinning, so it served inconsistent variants.
# Rebuild A/B client-side (JS) later if needed. Revalidate HTML so future edits
# propagate immediately instead of living in caches.
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "no-cache, must-revalidate, max-age=0"
</FilesMatch>
